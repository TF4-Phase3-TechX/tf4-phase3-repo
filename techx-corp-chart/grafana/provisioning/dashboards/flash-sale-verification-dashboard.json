  "panels": [
    {
      "id": 100,
      "title": "Traffic & Load-Generator Activity",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "Load-generator traffic activity (spans/s)",
      "description": "Activity rate of the load generator service (spans per second). Shows 0 when load generator is idle.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "editorMode": "code",
          "expr": "sum(rate(traces_span_metrics_calls_total{service_name=\"load-generator\"}[5m])) or vector(0)",
          "legendFormat": "Loadgen Activity",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Frontend Inbound RPS",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "gridPos": { "h": 8, "w": 10, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": [ "mean", "max" ], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "editorMode": "code",
          "expr": "sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval]))",
          "legendFormat": "Frontend RPS",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Services RPS & Error Rate",
      "description": "Real-time request rate and error rate grouped by service.",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "options": { "readOnly": true, "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "editorMode": "code",
          "expr": "sum by (service_name) (rate(traces_span_metrics_calls_total{span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval]))",
          "legendFormat": "RPS",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "editorMode": "code",
          "expr": "sum by (service_name) (rate(traces_span_metrics_calls_total{span_kind=\"SPAN_KIND_SERVER\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum by (service_name) (rate(traces_span_metrics_calls_total{span_kind=\"SPAN_KIND_SERVER\"}[$__rate_interval])) * 100",
          "legendFormat": "Error Rate %",
          "refId": "B"
        }
      ]
    },
    {
      "id": 200,
      "title": "Business SLO Verification (Frontend Customer-Facing)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "title": "Storefront (Browse) Latency Percentiles",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "showPoints": "never" },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1000.0 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": [ "mean", "max" ], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=~\"GET /|GET /product.*|GET /api/products.*|GET /api/data.*\"}[$__rate_interval])))",
          "legendFormat": "p50 Latency",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=~\"GET /|GET /product.*|GET /api/products.*|GET /api/data.*\"}[$__rate_interval])))",
          "legendFormat": "p95 Latency",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=~\"GET /|GET /product.*|GET /api/products.*|GET /api/data.*\"}[$__rate_interval])))",
          "legendFormat": "p99 Latency",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "title": "Browse/Search Success Rate",
      "description": "Browse success rate. Minimum traffic: 20 requests/5m.",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 100,
          "min": 0,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 99.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "editorMode": "code",
          "expr": "100 * sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=~\"GET /|GET /product.*|GET /api/products.*|GET /api/data.*\", status_code!=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=~\"GET /|GET /product.*|GET /api/products.*|GET /api/data.*\"}[$__rate_interval]))",
          "legendFormat": "Browse SLO",
          "refId": "A"
        }
      ]
    },
