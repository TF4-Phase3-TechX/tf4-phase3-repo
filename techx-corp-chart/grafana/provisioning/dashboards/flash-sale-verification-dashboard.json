      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "editorMode": "code",
          "expr": "(max by (k8s_node_name) (k8s_node_cpu_usage) / on (k8s_node_name) label_replace(max by (instance) (machine_cpu_cores{job=\"kubernetes-nodes-cadvisor\"}), \"k8s_node_name\", \"$1\", \"instance\", \"(.*)\")) * 100",
          "legendFormat": "{{k8s_node_name}}",
          "refId": "A"
        }
