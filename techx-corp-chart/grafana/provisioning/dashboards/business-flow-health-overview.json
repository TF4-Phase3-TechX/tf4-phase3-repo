  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "webstore-metrics"
      },
      "description": "Customer-facing browse/search success rate based on frontend server spans.",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 99 },
              { "color": "green", "value": 99.5 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "100 * sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=~\"GET /|GET /product.*|GET /api/products.*|GET /api/data.*\", status_code!=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=~\"GET /|GET /product.*|GET /api/products.*|GET /api/data.*\"}[$__rate_interval])) or vector(0)",
          "legendFormat": "browse success",
          "refId": "A"
        }
      ],
      "title": "Browse Success",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "description": "Cart API success rate from frontend spans.",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 99 },
              { "color": "green", "value": 99.5 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "100 * sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=~\"(GET|POST|DELETE) /api/cart\", status_code!=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=~\"(GET|POST|DELETE) /api/cart\"}[$__rate_interval])) or vector(0)",
          "legendFormat": "cart success",
          "refId": "A"
        }
      ],
      "title": "Cart Success",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "description": "Checkout success rate for POST /api/checkout. This is the revenue-critical SLO surface.",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 99 },
              { "color": "green", "value": 99.5 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "100 * sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=\"POST /api/checkout\", status_code!=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=\"POST /api/checkout\"}[$__rate_interval])) or vector(0)",
          "legendFormat": "checkout success",
          "refId": "A"
        }
      ],
      "title": "Checkout Success",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "description": "Product review and AI flow success rate across product-reviews and llm spans.",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 98 },
              { "color": "green", "value": 99 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 15, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "100 * sum(rate(traces_span_metrics_calls_total{service_name=~\"product-reviews|llm\", status_code!=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_span_metrics_calls_total{service_name=~\"product-reviews|llm\"}[$__rate_interval])) or vector(0)",
          "legendFormat": "review + ai success",
          "refId": "A"
        }
      ],
      "title": "Review + AI Success",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "description": "Post-checkout async health based on Kafka/accounting/fraud-detection spans when available.",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 98 },
              { "color": "green", "value": 99 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "100 * sum(rate(traces_span_metrics_calls_total{service_name=~\"kafka|accounting|fraud-detection\", status_code!=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_span_metrics_calls_total{service_name=~\"kafka|accounting|fraud-detection\"}[$__rate_interval])) or vector(0)",
          "legendFormat": "post-checkout async success",
          "refId": "A"
        }
      ],
      "title": "Async Order Success",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "description": "Request rate grouped by business-critical service.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "sum by (service_name) (rate(traces_span_metrics_calls_total{service_name=~\"frontend|product-catalog|recommendation|ad|cart|checkout|payment|shipping|quote|email|product-reviews|llm|kafka|accounting|fraud-detection\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "title": "Business Flow Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "description": "p95 latency by service for the five core business flows.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=~\"frontend|product-catalog|recommendation|ad|cart|checkout|payment|shipping|quote|email|product-reviews|llm|kafka|accounting|fraud-detection\"}[$__rate_interval])))",
          "legendFormat": "{{service_name}} p95",
          "refId": "A"
        }
      ],
      "title": "Business Flow p95 Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "description": "Error request rate grouped by service. Use this with the success-rate stat panels to find the unhealthy flow.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "sum by (service_name) (rate(traces_span_metrics_calls_total{service_name=~\"frontend|product-catalog|recommendation|ad|cart|checkout|payment|shipping|quote|email|product-reviews|llm|kafka|accounting|fraud-detection\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}} errors",
          "refId": "A"
        }
      ],
      "title": "Business Flow Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "description": "Active Prometheus alerts owned by TF4. If this panel is empty, no alert is firing or ALERTS is not scraped.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 9,
      "options": {
        "showHeader": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "ALERTS{owner=~\"tf4-.*\", alertstate=~\"pending|firing\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "{{alertname}}",
          "refId": "A"
        }
      ],
      "title": "Active Alerts",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "description": "Deployment availability for services on the critical business paths.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 20 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "k8s_deployment_available{k8s_namespace_name=\"${namespace}\", k8s_deployment_name=~\"frontend|product-catalog|recommendation|ad|cart|checkout|payment|shipping|quote|email|product-reviews|llm|kafka|accounting|fraud-detection\"}",
          "legendFormat": "{{k8s_deployment_name}}",
          "refId": "A"
        }
      ],
      "title": "Critical Deployment Availability",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "description": "Pod restart delta over the last 10 minutes across business-critical services.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 20 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "sum(max_over_time(k8s_container_restarts{k8s_namespace_name=\"${namespace}\", k8s_container_name=~\"frontend|product-catalog|recommendation|ad|cart|checkout|payment|shipping|quote|email|product-reviews|llm|kafka|accounting|fraud-detection\"}[10m]) - min_over_time(k8s_container_restarts{k8s_namespace_name=\"${namespace}\", k8s_container_name=~\"frontend|product-catalog|recommendation|ad|cart|checkout|payment|shipping|quote|email|product-reviews|llm|kafka|accounting|fraud-detection\"}[10m])) by (k8s_pod_name, k8s_container_name)",
          "legendFormat": "{{k8s_pod_name}} / {{k8s_container_name}}",
          "refId": "A"
        }
      ],
      "title": "Critical Pod Restarts",
      "type": "timeseries"
    }
  ],
