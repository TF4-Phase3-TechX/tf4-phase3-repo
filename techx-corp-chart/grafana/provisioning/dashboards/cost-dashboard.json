  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "targetBlank": true,
      "title": "Baseline cost estimate",
      "type": "link",
      "url": "https://github.com/TF4-Phase3-TechX/tf4-phase3-repo/blob/main/docs/evidence/epic-04-cost-optimization/01-baseline-cost-estimate.md"
