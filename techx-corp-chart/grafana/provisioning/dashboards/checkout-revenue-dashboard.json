      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "sum by (service_name) (rate(traces_span_metrics_calls_total{service_name=~\"checkout|cart|product-catalog|currency|shipping|quote|payment|email|kafka|accounting|fraud-detection\"}[$__rate_interval]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
