  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "description": "Checkout success rate for POST /api/checkout. Primary revenue SLO surface.",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 99 },
              { "color": "green", "value": 99.5 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "100 * sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=\"POST /api/checkout\", status_code!=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=\"POST /api/checkout\"}[$__rate_interval])) or vector(0)",
          "legendFormat": "checkout success",
          "refId": "A"
        }
      ],
      "title": "Checkout Success Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "description": "Checkout request volume in the selected time range.",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "gray", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "sum(increase(traces_span_metrics_calls_total{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=\"POST /api/checkout\"}[$__range])) or vector(0)",
          "legendFormat": "checkout requests",
          "refId": "A"
        }
      ],
      "title": "Checkout Requests",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "description": "Payment service error rate. This panel is used to isolate checkout -> payment failures.",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.1 }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "sum(rate(traces_span_metrics_calls_total{service_name=\"payment\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) or vector(0)",
          "legendFormat": "payment errors",
          "refId": "A"
        }
      ],
      "title": "Payment Error Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "description": "Active alerts related to checkout, payment, Kafka, database, or critical runtime health.",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "sum(ALERTS{owner=~\"tf4-.*\", alertstate=~\"pending|firing\", alertname=~\".*(Checkout|Payment|Kafka|PostgreSQL|Valkey|Pod|Node|Frontend).*\"}) or vector(0)",
          "legendFormat": "active alerts",
          "refId": "A"
        }
      ],
      "title": "Active Revenue Alerts",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "description": "Checkout latency percentiles for POST /api/checkout.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=\"POST /api/checkout\"}[$__rate_interval])))",
          "legendFormat": "checkout p95",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=\"POST /api/checkout\"}[$__rate_interval])))",
          "legendFormat": "checkout p99",
          "refId": "B"
        }
      ],
      "title": "Checkout Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
      "description": "Checkout errors at the customer-facing frontend operation.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
          "expr": "sum(rate(traces_span_metrics_calls_total{service_name=\"frontend\", span_kind=\"SPAN_KIND_SERVER\", span_name=\"POST /api/checkout\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval]))",
          "legendFormat": "POST /api/checkout errors",
          "refId": "A"
        }
      ],
      "title": "Checkout Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "webstore-metrics" },
