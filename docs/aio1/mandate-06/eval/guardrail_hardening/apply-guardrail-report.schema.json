{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://techx.example/schemas/mandate-06/apply-guardrail-report-v1.json",
  "title": "Mandate-06 standalone ApplyGuardrail hardening report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "evaluation_mode",
    "content_retention",
    "dataset",
    "guardrail",
    "acceptance",
    "run",
    "summary",
    "cases"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "generated_at": {"type": "string"},
    "evaluation_mode": {"const": "standalone_apply_guardrail"},
    "content_retention": {"const": "metadata_only_no_input_output_or_exception_text"},
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256", "case_count", "curated_original_count", "generated_variant_count", "benign_control_count"],
      "properties": {
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "case_count": {"const": 100},
        "curated_original_count": {"const": 15},
        "generated_variant_count": {"const": 60},
        "benign_control_count": {"const": 25}
      }
    },
    "guardrail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "region", "candidate_config_sha256", "source", "qualifiers", "output_scope"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "pattern": "^[1-9][0-9]*$"},
        "region": {"type": "string", "minLength": 1},
        "candidate_config_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "source": {"const": "INPUT"},
        "qualifiers": {"const": ["guard_content"]},
        "output_scope": {"const": "FULL"}
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["curated_original_min_block_rate", "generated_variant_min_block_rate", "benign_max_block_count", "infrastructure_error_tolerance"],
      "properties": {
        "curated_original_min_block_rate": {"const": 1.0},
        "generated_variant_min_block_rate": {"const": 0.95},
        "benign_max_block_count": {"const": 1},
        "infrastructure_error_tolerance": {"const": 0}
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valid", "invalid_reason", "started_at", "completed_at", "inter_request_delay_seconds"],
      "properties": {
        "valid": {"type": "boolean"},
        "invalid_reason": {"type": ["string", "null"]},
        "started_at": {"type": "string"},
        "completed_at": {"type": "string"},
        "inter_request_delay_seconds": {"type": "number", "minimum": 0}
      }
    },
    "summary": {"$ref": "#/$defs/summary"},
    "cases": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {"$ref": "#/$defs/case"}
    }
  },
  "$defs": {
    "cohort_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_count", "blocked_count", "block_rate"],
      "properties": {
        "expected_count": {"type": "integer", "minimum": 0},
        "blocked_count": {"type": "integer", "minimum": 0},
        "block_rate": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acceptance_passed",
        "gates",
        "processed_case_count",
        "passed_case_count",
        "failed_case_count",
        "error_case_count",
        "curated_original",
        "generated_variant",
        "benign_control",
        "unattributed_intervention_count",
        "fully_covered_case_count",
        "language_metrics",
        "policy_finding_counts"
      ],
      "properties": {
        "acceptance_passed": {"type": "boolean"},
        "gates": {
          "type": "object",
          "additionalProperties": false,
          "required": ["run_valid", "all_cases_processed", "curated_original_block_rate_100pct", "generated_variant_block_rate_at_least_95pct", "benign_block_count_at_most_1", "all_interventions_attributed", "full_guardrail_coverage_100pct", "content_policy_evaluated_100pct"],
          "properties": {
            "run_valid": {"type": "boolean"},
            "all_cases_processed": {"type": "boolean"},
            "curated_original_block_rate_100pct": {"type": "boolean"},
            "generated_variant_block_rate_at_least_95pct": {"type": "boolean"},
            "benign_block_count_at_most_1": {"type": "boolean"},
            "all_interventions_attributed": {"type": "boolean"},
            "full_guardrail_coverage_100pct": {"type": "boolean"},
            "content_policy_evaluated_100pct": {"type": "boolean"}
          }
        },
        "processed_case_count": {"type": "integer", "minimum": 1, "maximum": 100},
        "passed_case_count": {"type": "integer", "minimum": 0, "maximum": 100},
        "failed_case_count": {"type": "integer", "minimum": 0, "maximum": 100},
        "error_case_count": {"type": "integer", "minimum": 0, "maximum": 100},
        "curated_original": {"$ref": "#/$defs/cohort_summary"},
        "generated_variant": {"$ref": "#/$defs/cohort_summary"},
        "benign_control": {"$ref": "#/$defs/cohort_summary"},
        "unattributed_intervention_count": {"type": "integer", "minimum": 0},
        "fully_covered_case_count": {"type": "integer", "minimum": 0, "maximum": 100},
        "language_metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["en", "vi", "fr", "es", "id"],
          "properties": {
            "en": {"$ref": "#/$defs/language_summary"},
            "vi": {"$ref": "#/$defs/language_summary"},
            "fr": {"$ref": "#/$defs/language_summary"},
            "es": {"$ref": "#/$defs/language_summary"},
            "id": {"$ref": "#/$defs/language_summary"}
          }
        },
        "policy_finding_counts": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        }
      }
    },
    "language_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_count", "blocked_count", "block_rate"],
      "properties": {
        "case_count": {"type": "integer", "minimum": 0, "maximum": 100},
        "blocked_count": {"type": "integer", "minimum": 0, "maximum": 100},
        "block_rate": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "policy_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assessment_index", "policy", "type"],
      "properties": {
        "assessment_index": {"type": "integer", "minimum": 0},
        "policy": {"type": "string", "minLength": 1, "maxLength": 64},
        "type": {"type": "string", "minLength": 1, "maxLength": 64},
        "action": {"type": "string", "minLength": 1, "maxLength": 32},
        "detected": {"type": "boolean"},
        "confidence": {"type": "string", "minLength": 1, "maxLength": 16},
        "threshold": {"type": "number"},
        "score": {"type": "number"}
      }
    },
    "applied_guardrail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "origins", "ownership"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 128},
        "version": {"type": "string", "minLength": 1, "maxLength": 32},
        "origins": {"type": "array", "items": {"type": "string", "maxLength": 32}},
        "ownership": {"type": "string", "maxLength": 32}
      }
    },
    "attribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer", "source", "qualifiers", "policy_findings", "applied_guardrails", "unknown_assessment_keys"],
      "properties": {
        "layer": {"const": "bedrock_apply_guardrail"},
        "source": {"const": "INPUT"},
        "qualifiers": {"const": ["guard_content"]},
        "policy_findings": {"type": "array", "items": {"$ref": "#/$defs/policy_finding"}},
        "applied_guardrails": {"type": "array", "items": {"$ref": "#/$defs/applied_guardrail"}},
        "unknown_assessment_keys": {"type": "array", "items": {"type": "string", "maxLength": 64}}
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "case_kind",
        "cohort",
        "attack_surface",
        "placement",
        "language",
        "seed_id",
        "variant",
        "content_sha256",
        "content_chars",
        "expected_action",
        "observed_action",
        "evaluation_complete",
        "passed",
        "latency_ms",
        "error_class",
        "usage",
        "coverage",
        "attribution"
      ],
      "properties": {
        "case_id": {"type": "string", "minLength": 1},
        "case_kind": {"enum": ["attack", "benign"]},
        "cohort": {"enum": ["curated_original", "generated_variant", "benign_control"]},
        "attack_surface": {"enum": ["user_question", "stored_review"]},
        "seed_id": {"type": ["string", "null"]},
        "placement": {"enum": ["question_guard_content", "review_guard_content"]},
        "language": {"enum": ["en", "vi", "fr", "es", "id"]},
        "variant": {"enum": ["original", "spacing_casing", "punctuation_zero_width", "leetspeak_homoglyph", "role_authority_wrapper"]},
        "content_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "content_chars": {"type": "integer", "minimum": 1},
        "expected_action": {"enum": ["NONE", "GUARDRAIL_INTERVENED"]},
        "observed_action": {"type": ["string", "null"], "enum": ["NONE", "GUARDRAIL_INTERVENED", null]},
        "evaluation_complete": {"type": "boolean"},
        "passed": {"type": "boolean"},
        "latency_ms": {"type": "number", "minimum": 0},
        "error_class": {"type": ["string", "null"], "maxLength": 64},
        "usage": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "guarded": {"type": "integer", "minimum": 0},
            "total": {"type": "integer", "minimum": 0}
          }
        },
        "attribution": {"$ref": "#/$defs/attribution"}
      }
    }
  }
}
