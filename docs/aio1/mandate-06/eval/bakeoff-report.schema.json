{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mandate 06 sanitized Bedrock bake-off report",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "dataset_sha256",
    "guardrail_id",
    "guardrail_version",
    "region",
    "repetitions",
    "inter_request_delay_seconds",
    "content_retention",
    "models",
    "selection"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "dataset_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "guardrail_id": {"type": "string"},
    "guardrail_version": {"type": "string", "pattern": "^[1-9][0-9]*$"},
    "region": {"const": "us-east-1"},
    "repetitions": {"const": 3},
    "inter_request_delay_seconds": {"type": "number", "minimum": 0},
    "content_retention": {"const": "metadata_only_no_prompt_review_or_response_content"},
    "models": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["model", "model_id", "hard_gates", "eligible", "metrics", "cases"],
        "properties": {
          "model": {"enum": ["haiku-4.5", "qwen3-next-80b-a3b", "nova-2-lite"]},
          "model_id": {"type": "string"},
          "hard_gates": {"type": "object", "additionalProperties": {"type": "boolean"}},
          "eligible": {"type": "boolean"},
          "metrics": {"type": "object"},
          "cases": {
            "type": "array",
            "minItems": 90,
            "maxItems": 90,
            "items": {
              "type": "object",
              "required": ["case_id", "category", "repetition", "outcome", "passed", "no_sensitive_leak"],
              "not": {
                "anyOf": [
                  {"required": ["prompt"]},
                  {"required": ["question"]},
                  {"required": ["review"]},
                  {"required": ["response"]}
                ]
              }
            }
          }
        }
      }
    },
    "selection": {
      "type": "object",
      "required": ["winner", "rule", "scores"]
    }
  },
  "additionalProperties": false
}
