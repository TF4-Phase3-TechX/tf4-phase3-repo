{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListGuardrailsForChangeControl",
      "Effect": "Allow",
      "Action": "bedrock:ListGuardrails",
      "Resource": "*"
    },
    {
      "Sid": "UpdateAndVersionExistingProductionGuardrailDraft",
      "Effect": "Allow",
      "Action": [
        "bedrock:UpdateGuardrail",
        "bedrock:GetGuardrail",
        "bedrock:CreateGuardrailVersion"
      ],
      "Resource": "arn:aws:bedrock:us-east-1:511825856493:guardrail/wckqh9dms6qa"
    },
    {
      "Sid": "EvaluateCandidateAcrossUSGuardrailProfile",
      "Effect": "Allow",
      "Action": "bedrock:ApplyGuardrail",
      "Resource": [
        "arn:aws:bedrock:us-east-1:511825856493:guardrail/wckqh9dms6qa",
        "arn:aws:bedrock:us-east-1:511825856493:guardrail-profile/us.guardrail.v1:0",
        "arn:aws:bedrock:us-east-2:511825856493:guardrail-profile/us.guardrail.v1:0",
        "arn:aws:bedrock:us-west-2:511825856493:guardrail-profile/us.guardrail.v1:0"
      ]
    }
  ]
}
