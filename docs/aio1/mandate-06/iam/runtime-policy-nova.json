{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "InvokeProductionNovaProfileWithPinnedGuardrail",
      "Effect": "Allow",
      "Action": "bedrock:InvokeModel",
      "Resource": [
        "arn:aws:bedrock:us-east-1:511825856493:inference-profile/us.amazon.nova-2-lite-v1:0",
        "arn:aws:bedrock:us-east-1::foundation-model/amazon.nova-2-lite-v1:0",
        "arn:aws:bedrock:us-east-2::foundation-model/amazon.nova-2-lite-v1:0",
        "arn:aws:bedrock:us-west-2::foundation-model/amazon.nova-2-lite-v1:0"
      ],
      "Condition": {
        "StringEquals": {
          "bedrock:GuardrailIdentifier": "arn:aws:bedrock:us-east-1:511825856493:guardrail/wckqh9dms6qa:1"
        }
      }
    },
    {
      "Sid": "UseOnlyProductionGuardrail",
      "Effect": "Allow",
      "Action": "bedrock:ApplyGuardrail",
      "Resource": "arn:aws:bedrock:us-east-1:511825856493:guardrail/wckqh9dms6qa"
    },
    {
      "Sid": "DenyInferenceWithoutProductionGuardrail",
      "Effect": "Deny",
      "Action": ["bedrock:InvokeModel", "bedrock:InvokeModelWithResponseStream"],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "bedrock:GuardrailIdentifier": "arn:aws:bedrock:us-east-1:511825856493:guardrail/wckqh9dms6qa:1"
        }
      }
    }
  ]
}
